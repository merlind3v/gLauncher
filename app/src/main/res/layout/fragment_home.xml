<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    android:orientation="vertical"
    tools:context=".ui.HomeFragment">

    <!-- Placeholder layout for locking screen-->
    <FrameLayout
        android:id="@+id/lock"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:contentDescription="@string/lock_layout_description" />

    <!-- Placeholder layout for showing recent apps-->
    <FrameLayout
        android:id="@+id/recents"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:contentDescription="@string/recents_layout_description" />

    <!-- Single terminal-style date line: @date HH:MM_Qn-Snn_DD-MM -->
    <LinearLayout
        android:id="@+id/dateTimeLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="56dp"
        android:orientation="vertical"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:id="@+id/date"
            style="@style/TextDefault"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="3dp"
            android:textSize="@dimen/date_size"
            tools:text="\@date 13:45_Q3-S01_03-07" />

        <!-- Estado en vivo del scheduler de galatea-backend -->
        <LinearLayout
            android:id="@+id/schedulerLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/schedulerConexion"
                style="@style/TextSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="3dp"
                tools:text="Galatea: conectado" />

            <TextView
                android:id="@+id/schedulerNombre"
                style="@style/TextDefault"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="3dp"
                android:visibility="gone"
                tools:text="Modelado 3D Estructura"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/schedulerEstado"
                style="@style/TextSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="3dp"
                android:visibility="gone"
                tools:text="en progreso · 07:30-09:30"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/schedulerAccionConfirmar"
                style="@style/TextSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="?android:attr/selectableItemBackground"
                android:paddingHorizontal="3dp"
                android:paddingVertical="4dp"
                android:text="[ confirmar ]"
                android:visibility="gone"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/schedulerAccionCompletar"
                style="@style/TextSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="?android:attr/selectableItemBackground"
                android:paddingHorizontal="3dp"
                android:paddingVertical="4dp"
                android:text="[ completar ]"
                android:visibility="gone"
                tools:visibility="visible" />

            <LinearLayout
                android:id="@+id/schedulerAccionesExtender"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/schedulerAccionExtender15"
                    style="@style/TextSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="4dp"
                    android:text="[ +15m ]" />

                <TextView
                    android:id="@+id/schedulerAccionExtender30"
                    style="@style/TextSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="4dp"
                    android:text="[ +30m ]" />

                <TextView
                    android:id="@+id/schedulerAccionExtender60"
                    style="@style/TextSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="4dp"
                    android:text="[ +1h ]" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Quick launch: type an app name to open it -->
    <LinearLayout
        android:id="@+id/quickLaunchLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="bottom"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="112dp"
        android:paddingBottom="48dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/homeSearchResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:fadingEdgeLength="24dp"
            android:requiresFadingEdge="vertical"
            android:visibility="gone"
            tools:visibility="visible" />

        <androidx.appcompat.widget.SearchView
            android:id="@+id/homeSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:imeOptions="actionSearch"
            android:paddingHorizontal="0dp"
            android:paddingVertical="0dp"
            android:textCursorDrawable="@null"
            app:closeIcon="@null"
            app:iconifiedByDefault="false"
            app:queryBackground="@null"
            app:queryHint="@string/app_search_hint"
            app:searchIcon="@null"
            app:theme="@style/AppSearchText" />

    </LinearLayout>

    <TextView
        android:id="@+id/firstRunTips"
        style="@style/TextSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="56dp"
        android:text="@string/swipe_up_for_apps"
        android:visibility="gone"
        tools:visibility="visible" />

    <!-- Set default launcher -->
    <TextView
        android:id="@+id/setDefaultLauncher"
        style="@style/TextMedium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="56dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/set_as_default_launcher_u"
        android:visibility="gone" />
</FrameLayout>